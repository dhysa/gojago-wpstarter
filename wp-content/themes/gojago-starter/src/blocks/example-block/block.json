{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "gojago-starter/example-block",
  "version": "1.0.0",
  "title": "Gojago Example Card",
  "category": "design",
  "icon": "index-card",
  "description": "Editable proof card with inspector controls.",
  "textdomain": "gojago-starter",
  "attributes": {
    "eyebrow": { "type": "string", "default": "Proof point" },
    "heading": { "type": "string", "default": "Structured Gutenberg editing" },
    "body": { "type": "string", "default": "This example block demonstrates editable content, inspector controls, accessible markup, and build tooling." },
    "accent": { "type": "string", "default": "#0f766e" }
  },
  "editorScript": "file:./index.js",
  "style": "file:./style-index.css",
  "editorStyle": "file:./index.css"
}
