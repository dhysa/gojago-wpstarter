{
  "name": "gojago-starter",
  "version": "1.1.8",
  "private": true,
  "scripts": {
    "dev": "wp-scripts start resources/views/partials/block/example-block/index.js --output-path=public/blocks/example-block & tailwindcss -i ./resources/styles/app.css -o ./public/css/app.css --watch",
    "build": "wp-scripts build resources/views/partials/block/example-block/index.js --output-path=public/blocks/example-block && cp resources/views/partials/block/example-block/block.json public/blocks/example-block/block.json && tailwindcss -i ./resources/styles/app.css -o ./public/css/app.css --minify"
  },
  "dependencies": {
    "@wordpress/block-editor": "latest",
    "@wordpress/blocks": "latest",
    "@wordpress/components": "latest",
    "@wordpress/element": "latest",
    "@wordpress/i18n": "latest"
  },
  "devDependencies": {
    "@wordpress/scripts": "latest",
    "tailwindcss": "latest",
    "@tailwindcss/cli": "latest",
    "postcss": "latest",
    "autoprefixer": "latest"
  }
}
