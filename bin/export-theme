#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
THEME_SLUG="${THEME_SLUG:-gojago-starter}"
THEME_DIR="$ROOT_DIR/wp-content/themes/$THEME_SLUG"
VERSION="$(tr -d '[:space:]' < "$ROOT_DIR/STARTER_VERSION")"
DIST_DIR="$ROOT_DIR/dist"
EXPORT_DIR="$DIST_DIR/${THEME_SLUG}-v${VERSION}"
ZIP_FILE="$DIST_DIR/${THEME_SLUG}-v${VERSION}.zip"
SKIP_BUILD="${SKIP_BUILD:-0}"

if [[ ! -d "$THEME_DIR" ]]; then
  echo "Theme directory not found: $THEME_DIR" >&2
  exit 1
fi

if [[ "$SKIP_BUILD" != "1" && -f "$THEME_DIR/package.json" ]]; then
  if ! command -v npm >/dev/null 2>&1; then
    echo "npm is required to build the theme. Re-run with SKIP_BUILD=1 to export without building." >&2
    exit 1
  fi

  echo "Building theme assets..."
  (cd "$THEME_DIR" && npm install && npm run build)
fi

rm -rf "$EXPORT_DIR" "$ZIP_FILE"
mkdir -p "$DIST_DIR"

echo "Copying theme to $EXPORT_DIR..."
rsync -a \
  --exclude='.git/' \
  --exclude='.DS_Store' \
  --exclude='node_modules/' \
  --exclude='npm-debug.log*' \
  "$THEME_DIR/" "$EXPORT_DIR/"

echo "Creating $ZIP_FILE..."
(cd "$DIST_DIR" && zip -qr "$(basename "$ZIP_FILE")" "$(basename "$EXPORT_DIR")")

echo "Done."
echo "Theme folder: $EXPORT_DIR"
echo "Theme zip:    $ZIP_FILE"
