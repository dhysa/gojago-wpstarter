#!/usr/bin/env node

const fs = require('fs');
const path = require('path');

const version = process.argv[2];

if (!version || !/^\d+\.\d+\.\d+$/.test(version)) {
  console.error('Usage: bin/bump-version <major.minor.patch>');
  console.error('Example: bin/bump-version 1.1.0');
  process.exit(1);
}

const rootDir = path.resolve(__dirname, '..');
const themeDir = path.join(rootDir, 'wp-content/themes/gojago-starter');
const starterVersionPath = path.join(rootDir, 'STARTER_VERSION');
const packageJsonPath = path.join(themeDir, 'package.json');
const styleCssPath = path.join(themeDir, 'style.css');

fs.writeFileSync(starterVersionPath, `${version}\n`);

const packageJson = JSON.parse(fs.readFileSync(packageJsonPath, 'utf8'));
packageJson.version = version;
fs.writeFileSync(packageJsonPath, `${JSON.stringify(packageJson, null, 2)}\n`);

const styleCss = fs.readFileSync(styleCssPath, 'utf8');
const versionHeaderPattern = /^Version:\s*.*$/m;

if (!versionHeaderPattern.test(styleCss)) {
  console.error(`Could not find Version header in ${styleCssPath}`);
  process.exit(1);
}

const updatedStyleCss = styleCss.replace(versionHeaderPattern, `Version: ${version}`);
fs.writeFileSync(styleCssPath, updatedStyleCss);

console.log(`Starter and theme version bumped to ${version}.`);
